{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "JunQi Desktop",
  "mainBinaryName": "junqi-desktop",
  "version": "1.2.28",
  "identifier": "com.junqi.junqidesktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "JunQi Desktop",
        "width": 1440,
        "height": 900,
        "minWidth": 560,
        "minHeight": 420,
        "transparent": true,
        "backgroundColor": "#0c1015",
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "resizable": true,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/skills/hatch-pet": "skills/hatch-pet"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "allowDowngrades": true,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "installer-hooks.nsh",
        "languages": [
          "English",
          "SimpChinese"
        ],
        "displayLanguageSelector": true
      },
      "wix": {
        "language": [
          "en-US",
          "zh-CN"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "hardenedRuntime": true,
      "entitlements": "JunQi.entitlements",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2QkQxQzQ2NjQxNkZENzcKUldSMy9SWmtSaHk5OXJMRUR1dUJXdXZLZEtJWFlwdm5tdzRYRHIzSXA5V0J1czBNVWRvMXR4V3EK",
      "endpoints": []
    },
    "shell": {
      "open": true
    }
  }
}
